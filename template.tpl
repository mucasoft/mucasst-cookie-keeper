___SANDBOXED_JS_FOR_SERVER___

const getRequestHeader = require('getRequestHeader');
const getCookieValues = require('getCookieValues');
const setCookie = require('setCookie');

const keeperPlan = getRequestHeader('x-mucasst-cookie-keeper');

if (keeperPlan) {
  let maxAgeSeconds = 0;
  
  if (keeperPlan === 'custom') {
     maxAgeSeconds = 31536000; // Plan 4 (Business) = 365 days
  } else if (keeperPlan === 'standard') {
     maxAgeSeconds = 7776000;  // Plan 2 & 3 (Pro/Advanced) = 90 days
  }

  if (maxAgeSeconds > 0) {
    const cookiesToExtend = [
      '_ga',          // Google Analytics
      '_fbp',         // Facebook Pixel
      '_gcl_au',      // Google Ads
      '_ttp',         // TikTok Pixel
      '_scid',        // Snapchat Pixel
      '_pin_unauth',  // Pinterest Tag
      '_uetsid',      // Microsoft Bing Ads
      '_uetvid',      // Microsoft Bing Ads
      '_clck'         // Microsoft Clarity
    ];

    cookiesToExtend.forEach(cookieName => {
      const cookieValues = getCookieValues(cookieName);
      
      if (cookieValues && cookieValues.length > 0) {
        setCookie(cookieName, cookieValues[0], {
          domain: 'auto',
          path: '/',
          maxAge: maxAgeSeconds,
          secure: true,
          httpOnly: false
        });
      }
    });
  }
}

data.gtmOnSuccess();


